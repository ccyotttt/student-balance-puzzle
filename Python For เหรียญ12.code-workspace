        let weighCount = 0;

        function weigh() {
            weighCount++;
            let leftSum = getSum(1);
            let rightSum = getSum(2);
            
            // ตรรกะตัดสินผล
            let result = (leftSum === rightSum) ? "สมดุล" : (leftSum > rightSum ? "เอียงซ้าย" : "เอียงขวา");
            
            // AI ภายในเกมให้ Feedback ตามสถานการณ์
            let feedback = `ผลคือ ${result} ครับ ครั้งที่ชั่ง: ${weighCount}/3. `;
            if(weighCount === 1) feedback += "จำไว้ว่าถ้าสมดุล เหรียญที่เหลือคือเหรียญที่น่าสงสัยครับ";
            
            document.getElementById('ai-feedback').innerText = feedback;
            
            if(weighCount >= 3) alert("ครบ 3 ครั้งแล้ว! ลองทายดูว่าเหรียญไหนพิเศษ?");
        }

        function getSum(side) {
