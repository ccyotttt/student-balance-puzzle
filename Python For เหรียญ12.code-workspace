            return 0; 
        }

        // สร้างเหรียญ
        const coinsDiv = document.getElementById('coins');
        for(let i=0; i<12; i++) {
            let div = document.createElement('div');
            div.className = 'coin';
            div.innerText = 'เหรียญ ' + (i+1);
            div.onclick = () => alert('คลิกเหรียญ ' + (i+1));
            coinsDiv.appendChild(div);
        }
    </script>
</body>
</html>


